# Copy to .env in the directory you run agentproof-scan from, then replace the
# placeholder with a real key. .env is gitignored — never commit a real key.
#
# The scanner REFUSES to run while a value is still a placeholder. A scan that
# cannot reach your agent must not report "clean".
#
#
# Do NOT put quotes around the value. The loader takes the value verbatim --
# `KEY="abc"` gives you a key that literally contains the quote characters.
# (It never rewrites a value: a credential is a literal, and this tool matches
# literals. Changing one here would create false positives and negatives
# somewhere we cannot see.)
#
# Free Gemini key: https://aistudio.google.com/apikey
GEMINI_API_KEY=PASTE_YOUR_KEY_HERE

# Only for --url / --agent-config runs that need an auth header. The flag takes
# the environment variable NAME, never the value:
#   --auth-header "Authorization=Bearer {MY_AGENT_KEY}"
MY_AGENT_KEY=sk-your-real-key
